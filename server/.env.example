# Core environment
APP_ENV=development

# Primary database URL (direct connection, usually port 5432)
# Used by main request session and migrations (Alembic)
DATABASE_URL=postgresql://postgres:<password>@<project-ref>.supabase.co:5432/postgres

# Pooled database URL (pooler connection, usually port 6543)
# Used by analytics/background services in hosted environments (e.g. Render)
# Optional locally; if omitted, pooled services fall back to DATABASE_URL
DATABASE_POOL_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# SQLAlchemy pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO_SQL=false

# Supabase auth
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# CORS and contact integrations
CORS_ORIGINS=http://localhost:3000
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_TIMEOUT=10
CONTACT_TELEGRAM_ENABLED=false
CONTACT_TELEGRAM_BOT_TOKEN=
CONTACT_TELEGRAM_CHAT_ID=
CONTACT_TELEGRAM_TIMEOUT=10
