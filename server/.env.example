# Core environment
APP_ENV=development

# Database configuration (Supabase Postgres)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
DATABASE_POOL_URL=postgresql://postgres.YOUR-PROJECT:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# SQLAlchemy pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO_SQL=false

# Supabase auth
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Supabase Storage (Phase 1: history re-download)
# Private bucket used to store tool outputs for signed-URL re-download.
# Free-tier Supabase caps objects at 50 MB (above our 20 MB input cap).
SUPABASE_STORAGE_BUCKET=tool-outputs

# CORS
CORS_ORIGINS=http://localhost:3000

# Contact form webhook (optional)
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_TIMEOUT=10
CONTACT_TELEGRAM_ENABLED=false
CONTACT_TELEGRAM_BOT_TOKEN=
CONTACT_TELEGRAM_CHAT_ID=
CONTACT_TELEGRAM_TIMEOUT=10
